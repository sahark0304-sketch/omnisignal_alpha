# ──────────────────────────────────────────────────────────────
#  OmniSignal Alpha — Environment Variables Template
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# OPERATING MODE: DEMO or LIVE
OPERATING_MODE=DEMO

# ── TELEGRAM ──
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_CHANNELS=-100xxxxxxxxx,-100yyyyyyyyy   # comma-separated channel IDs

# ── DISCORD ──
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_IDS=123456789,987654321          # comma-separated channel IDs

# ── GEMINI ──
GEMINI_API_KEY=your_gemini_api_key_here

# ── METATRADER 5 ──
MT5_LOGIN=123456
MT5_PASSWORD=your_mt5_password
MT5_SERVER=YourBroker-Demo                       # or YourBroker-Live
MT5_PATH=C:/Program Files/MetaTrader 5/terminal64.exe

# ── NOTIFICATIONS ──
NOTIFY_CHAT_ID=your_personal_telegram_chat_id
